# =============================================================================
# AHP Enterprise Platform - Environment Configuration (3차 개발)
# =============================================================================

# API Configuration
REACT_APP_API_URL=https://ahp-app-vuzk.onrender.com/api/v1
REACT_APP_WS_URL=wss://ahp-app-vuzk.onrender.com/ws

# Application Configuration
REACT_APP_NAME=AHP Enterprise Platform
REACT_APP_VERSION=3.0.0
REACT_APP_ENVIRONMENT=production

# Authentication
REACT_APP_TOKEN_EXPIRY=3600
REACT_APP_REFRESH_TOKEN_EXPIRY=604800

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_EXPORT=true

# Development Settings (only for development)
REACT_APP_DEBUG_MODE=false
REACT_APP_MOCK_API=false
REACT_APP_LOG_LEVEL=info

# Third-party Services (optional)
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_SENTRY_DSN=
REACT_APP_HOTJAR_ID=

# Build Configuration
GENERATE_SOURCEMAP=false
BUILD_PATH=build

# GitHub Pages
PUBLIC_URL=https://aebonlee.github.io/ahp_app